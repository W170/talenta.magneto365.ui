{
  "name": "magneto365-ui-monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/W170/talenta.magneto365.ui.git"
  },
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Magneto365 UI common components - Monorepo",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "generate:tokens": "node ./.scripts/generateTokens.js",
    "generate:css": "node ./.scripts/generateCssFiles.js",
    "tokens:generate": "pnpm --filter @magneto365-ui/design-tokens generate",
    "tokens:build": "pnpm --filter @magneto365-ui/design-tokens build",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky install && chmod +x .husky/pre-commit .husky/pre-push .husky/commit-msg",
    "prettier": "prettier --write ./**/*.{js,ts,jsx,tsx}  --list-different",
    "storybook": "pnpm generate:tokens && storybook dev -p 6006",
    "build-storybook": "pnpm generate:tokens && storybook build",
    "build:legacy": "pnpm --filter magneto365.ui build"
  },
  "author": "Wilmer H Muñoz Gomez",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/cli": "^7.21.0",
    "@babel/core": "^7.21.4",
    "@babel/eslint-parser": "^7.16.3",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.21.4",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^15.0.0",
    "@commitlint/config-conventional": "^15.0.0",
    "@mdx-js/react": "^2.1.5",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rollup/plugin-url": "^8.0.2",
    "@storybook/addon-actions": "^7.0.7",
    "@storybook/addon-essentials": "^7.0.7",
    "@storybook/addon-interactions": "^7.0.7",
    "@storybook/addon-links": "^7.0.7",
    "@storybook/addon-mdx-gfm": "^7.0.7",
    "@storybook/addon-postcss": "^2.0.0",
    "@storybook/mdx2-csf": "^1.0.0",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react": "^7.0.7",
    "@storybook/react-webpack5": "^7.0.7",
    "@storybook/testing-library": "^0.1.0",
    "@testing-library/react": "^12.1.2",
    "@types/jest": "^27.0.2",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^5.6.0",
    "@typescript-eslint/parser": "^5.6.0",
    "autoprefixer": "10.4.0",
    "axios": "^0.24.0",
    "babel-jest": "^27.3.1",
    "babel-loader": "^8.2.3",
    "babel-plugin-import": "^1.13.3",
    "css-loader": "^6.5.1",
    "cssnano": "^7.1.2",
    "dotenv": "^16.1.4",
    "eslint": "^8.4.1",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-storybook": "^0.6.11",
    "glob": "^13.0.1",
    "html-webpack-plugin": "^5.5.0",
    "husky": "^7.0.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.3.1",
    "postcss": "^8.4.35",
    "postcss-modules": "^6.0.0",
    "prettier": "^2.5.1",
    "pretty-quick": "^3.1.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "rollup": "^4.9.6",
    "rollup-plugin-babel": "^4.4.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-generate-package-json": "^3.2.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-sass": "^1.15.3",
    "sass": "^1.43.5",
    "sass-loader": "^12.3.0",
    "storybook": "^7.0.7",
    "storybook-css-modules": "^1.0.8",
    "string-hash": "^1.1.3",
    "tslib": "^2.6.2",
    "turbo": "^2.8.2",
    "typescript": "^5.3.3"
  }
}
