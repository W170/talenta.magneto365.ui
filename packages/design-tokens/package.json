{
  "name": "@magneto365-ui/design-tokens",
  "version": "0.1.0",
  "description": "Design tokens for Magneto365 UI Library - auto-generated from JSON sources",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/types/index.d.ts"
    },
    "./scss": "./src/scss/_index.scss",
    "./scss/*": "./src/scss/*.scss"
  },
  "scripts": {
    "generate": "node scripts/generateTokens.js",
    "build": "pnpm generate && rollup -c rollup.config.js --configPlugin typescript",
    "clean": "rm -rf dist src/index.ts src/scss"
  },
  "files": [
    "dist",
    "src/scss",
    "data",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
