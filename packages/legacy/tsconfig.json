{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@*": ["./*"],
      "@assets": ["assets/*"],
      "@components": ["components/*"],
      "@constants": ["constants"],
      "@shared": ["shared"],
      "@utils": ["utils"],
      "@tokens": ["shared/stylesheets/tokens/_index.scss"]
    }
  },
  "include": ["src/**/*"]
}
