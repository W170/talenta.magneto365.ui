{
  "name": "magneto365.ui",
  "version": "3.0.0",
  "description": "Magneto365 UI common components - Complete library (backward compatible)",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./Domain/Jobs": {
      "import": "./dist/esm/components/Domain/Jobs/index.js",
      "require": "./dist/cjs/components/Domain/Jobs/index.js",
      "types": "./dist/types/components/Domain/Jobs/index.d.ts"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js --configPlugin typescript",
    "postbuild": "node ../../.scripts/generateSeparateCssFiles.js legacy",
    "test": "jest --passWithNoTests",
    "lint": "eslint ./src --ext .ts,.tsx",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@magneto365-ui/primitives": "workspace:*",
    "@magneto365-ui/inputs": "workspace:*",
    "@magneto365-ui/feedback": "workspace:*",
    "@magneto365-ui/navigation": "workspace:*",
    "@magneto365-ui/data-display": "workspace:*",
    "@magneto365-ui/overlays": "workspace:*",
    "@magneto365-ui/shared": "workspace:*",
    "@magneto365-ui/domain": "workspace:*"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
