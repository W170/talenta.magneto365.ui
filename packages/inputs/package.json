{
  "name": "@magneto365-ui/inputs",
  "version": "3.0.0",
  "description": "Form controls and interactive input elements",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:rollup && pnpm build:css",
    "build:rollup": "rollup -c rollup.config.js",
    "build:css": "node ../../.scripts/generateComponentCss.js inputs",
    "dev": "rollup -c rollup.config.js --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint ./src --ext .ts,.tsx",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@magneto365-ui/design-tokens": "workspace:*",
    "@magneto365-ui/shared": "workspace:*",
    "@magneto365-ui/primitives": "workspace:*"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
