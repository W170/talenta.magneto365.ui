    },
    "./css/Tag.min.css": "./dist/css/Tag.min.css",
    "./Button": {
      "import": "./dist/esm/components/Button/index.js",
      "require": "./dist/cjs/components/Button/index.js",
      "types": "./dist/types/components/Button/index.d.ts"
    },
    "./css/Button.min.css": "./dist/css/Button.min.css",
    "./Typography": {
      "import": "./dist/esm/components/Typography/index.js",
      "require": "./dist/cjs/components/Typography/index.js",
      "types": "./dist/types/components/Typography/index.d.ts"
    },
    "./css/Typography.min.css": "./dist/css/Typography.min.css"
  },
  "sideEffects": [
    "dist/esm/components/Image/index.js",
    "dist/esm/components/Logo/index.js",
    "dist/esm/components/DotsLoader/index.js",
    "dist/esm/components/FlatLoader/index.js",
    "dist/esm/components/Icon/index.js",
    "dist/esm/components/Avatar/index.js",
    "dist/esm/components/BarLoader/index.js",
    "dist/esm/components/Loading/index.js",
    "dist/esm/components/Portal/index.js",
    "dist/esm/components/Badge/index.js",
    "dist/esm/components/Divider/index.js",
    "dist/esm/components/Tag/index.js",
    "dist/esm/components/Button/index.js",
    "dist/esm/components/Typography/index.js",
    "dist/css/*.css"
  ],
  "publishConfig": {
    "access": "public"
  }
}
