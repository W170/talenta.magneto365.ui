    },
    "./css/FlatLoader.min.css": "./dist/css/FlatLoader.min.css",
    "./Icon": {
      "import": "./dist/esm/components/Icon/index.js",
      "require": "./dist/cjs/components/Icon/index.js",
      "types": "./dist/types/components/Icon/index.d.ts"
    },
    "./css/Icon.min.css": "./dist/css/Icon.min.css",
    "./Avatar": {
      "import": "./dist/esm/components/Avatar/index.js",
      "require": "./dist/cjs/components/Avatar/index.js",
      "types": "./dist/types/components/Avatar/index.d.ts"
    },
    "./css/Avatar.min.css": "./dist/css/Avatar.min.css",
    "./BarLoader": {
      "import": "./dist/esm/components/BarLoader/index.js",
      "require": "./dist/cjs/components/BarLoader/index.js",
      "types": "./dist/types/components/BarLoader/index.d.ts"
    },
    "./css/BarLoader.min.css": "./dist/css/BarLoader.min.css",
    "./Loading": {
      "import": "./dist/esm/components/Loading/index.js",
      "require": "./dist/cjs/components/Loading/index.js",
      "types": "./dist/types/components/Loading/index.d.ts"
    },
    "./css/Loading.min.css": "./dist/css/Loading.min.css",
    "./Portal": {
      "import": "./dist/esm/components/Portal/index.js",
      "require": "./dist/cjs/components/Portal/index.js",
      "types": "./dist/types/components/Portal/index.d.ts"
    },
    "./css/Portal.min.css": "./dist/css/Portal.min.css",
    "./Badge": {
      "import": "./dist/esm/components/Badge/index.js",
      "require": "./dist/cjs/components/Badge/index.js",
      "types": "./dist/types/components/Badge/index.d.ts"
    },
    "./css/Badge.min.css": "./dist/css/Badge.min.css",
    "./Divider": {
      "import": "./dist/esm/components/Divider/index.js",
      "require": "./dist/cjs/components/Divider/index.js",
