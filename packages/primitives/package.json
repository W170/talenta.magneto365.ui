{
  "name": "@magneto365-ui/primitives",
  "version": "3.0.0",
  "description": "Core primitive components for magneto365.ui",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:rollup && pnpm build:css",
    "build:rollup": "rollup -c rollup.config.js",
    "build:css": "node ../../.scripts/generateComponentCss.js primitives",
    "dev": "rollup -c rollup.config.js --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint ./src --ext .ts,.tsx",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "dependencies": {
    "@magneto365-ui/design-tokens": "workspace:*",
    "@magneto365-ui/shared": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.0.6",
    "@rollup/plugin-typescript": "^8.3.0",
    "@rollup/plugin-url": "^8.0.1",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "autoprefixer": "10.4.0",
    "glob": "^13.0.1",
    "rollup": "^2.60.0",
    "rollup-plugin-dts": "^4.0.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.43.5",
    "string-hash": "^1.1.3",
    "typescript": "^4.4.4"
  },
  "exports": {
    "./package.json": "./package.json",
    "./Image": {
      "import": "./dist/esm/components/Image/index.js",
      "require": "./dist/cjs/components/Image/index.js",
      "types": "./dist/types/components/Image/index.d.ts"
    },
    "./css/Image.min.css": "./dist/css/Image.min.css",
    "./Logo": {
      "import": "./dist/esm/components/Logo/index.js",
      "require": "./dist/cjs/components/Logo/index.js",
      "types": "./dist/types/components/Logo/index.d.ts"
    },
    "./css/Logo.min.css": "./dist/css/Logo.min.css",
    "./DotsLoader": {
      "import": "./dist/esm/components/DotsLoader/index.js",
      "require": "./dist/cjs/components/DotsLoader/index.js",
      "types": "./dist/types/components/DotsLoader/index.d.ts"
    },
    "./css/DotsLoader.min.css": "./dist/css/DotsLoader.min.css",
    "./FlatLoader": {
      "import": "./dist/esm/components/FlatLoader/index.js",
      "require": "./dist/cjs/components/FlatLoader/index.js",
